{
  "name": "maoan-imgui-js",
  "version": "1.1.1",
  "description": "JavaScript bindings for Dear ImGui using Emscripten and TypeScript",
  "main": "./build/imgui.js",
  "module": "./build/imgui.js",
  "types": "./build/imgui.d.ts",
  "files": [
    "build",
    "package.json"
  ],
  "scripts": {
    "build": "make build-bind-imgui && npm run build-imgui",
    "clean": "make clean-bind-imgui && npm run clean-imgui",
    "watch": "npm run start-example",
    "start": "npm run start-example",
    "build-imgui": "tsc",
    "watch-imgui": "tsc --watch",
    "clean-imgui": "echo TODO: clean-imgui",
    "build-example": "cd example && npx vite build",
    "clean-example": "echo TODO: clean-example",
    "start-example": "cd example && npx vite",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "author": "maoan",
  "license": "MIT",
  "dependencies": {
    "@types/emscripten": "^1.39.4"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  }
}
